<!DOCTYPE html>

<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        @RenderSection("Metadata", required: false)

        <title>@ViewData["Title"] - UniversityMovieApp</title>

        @* styles *@
        <link rel="stylesheet" href="dist/bundle.css">

        <link rel="stylesheet" href="css/Shared/base.css">
        <link rel="stylesheet" href="css/Shared/layout.css">
        <link rel="stylesheet" href="css/Shared/palette.css">
        <link rel="stylesheet" href="css/Shared/modal-window.css">

        <link rel="stylesheet" href="css/Auth/auth-modal.css">
        @RenderSection("Styles", required: false)
    </head>
    <body>
        <partial name="AuthModal" />

        <main>
            <header>
                <a href="/">
                    <img src="icons/logo.svg" class="logo">
                </a>

                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <form asp-controller="Auth" asp-action="Logout" method="post">
                        <button type="submit" class="auth-button">Logout</button>
                    </form>
                }
                else
                {
                    <button id="auth-button" class="auth-button">Register</button>
                }
            </header>

            <div class="content">
                @RenderBody()
            </div>

            <footer>
                
            </footer>
        </main>

        @* scripts *@
        <script type="module" src="dist/bundle.js"></script>
    </body>
</html>